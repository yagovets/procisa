#!/bin/bash

set -e

COUNT=2
BASE_DIR="$(pwd)"

echo "===================================="
echo "   NDR INSTALLER (FINAL LIMPIO)"
echo "===================================="

# ============================
# 1. DEPENDENCIAS
# ============================
echo "[1/4] Instalando dependencias..."

sudo apt update
sudo apt install -y git docker.io docker-compose-plugin

sudo systemctl enable --now docker

# ============================
# 2. ESTRUCTURA
# ============================
echo "[2/4] Creando estructura..."

mkdir -p fluentd
mkdir -p suricata/logs
mkdir -p nginx

# fluentd.conf
cat <<EOF > fluentd/fluent.conf
<source>
  @type tail
  path /var/log/suricata/eve.json
  pos_file /fluentd/log/eve.pos
  tag suricata
  <parse>
    @type json
  </parse>
</source>

<match suricata>
  @type stdout
</match>
EOF

# ============================
# 3. MIKROCATA
# ============================
echo "[3/4] Configurando Mikrocata..."

if [ ! -d "$BASE_DIR/mikrocata2selks" ]; then
    git clone https://github.com/angolo40/mikrocata2selks.git
fi

sudo mkdir -p /etc/systemd/network
sudo mkdir -p /etc/systemd/system
sudo mkdir -p /var/lib/mikrocata

for ((i=0; i<COUNT; i++))
do
    echo "→ tzsp$i"

    sudo cp mikrocata2selks/tzsp.netdev /etc/systemd/network/tzsp$i.netdev
    sudo cp mikrocata2selks/tzsp.network /etc/systemd/network/tzsp$i.network

    sudo sed -i "s/tzsp0/tzsp$i/g" /etc/systemd/network/tzsp$i.*

    sudo cp mikrocata2selks/mikrocata.py /usr/local/bin/mikrocataTZSP$i.py
    sudo chmod +x /usr/local/bin/mikrocataTZSP$i.py
    sudo sed -i "s/tzsp0/tzsp$i/g" /usr/local/bin/mikrocataTZSP$i.py

    sudo cp mikrocata2selks/mikrocata.service /etc/systemd/system/mikrocataTZSP$i.service
    sudo sed -i "s/mikrocata.py/mikrocataTZSP$i.py/g" /etc/systemd/system/mikrocataTZSP$i.service

    sudo touch /var/lib/mikrocata/savelists-tzsp$i.json
    sudo touch /var/lib/mikrocata/uptime-tzsp$i.bookmark
    sudo touch /var/lib/mikrocata/ignore-tzsp$i.conf
done

sudo systemctl daemon-reload

for ((i=0; i<COUNT; i++))
do
    sudo systemctl enable --now mikrocataTZSP$i.service
done

sudo systemctl enable systemd-networkd
sudo systemctl restart systemd-networkd

# ============================
# 4. DOCKER
# ============================
echo "[4/4] Levantando Docker..."

if [ -f docker-compose.yml ]; then
    docker compose down || true
    docker compose up -d
else
    echo "❌ Falta docker-compose.yml"
    exit 1
fi

echo "===================================="
echo "   SISTEMA LISTO 🚀"
echo "===================================="
